// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — Sistema de Gestão de Manutenção e Equipamentos
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN       // Dono da plataforma
  COMPANY_ADMIN     // Admin da empresa de manutenção
  COMPANY_MANAGER   // Gerente operacional da empresa
  TECHNICIAN        // Técnico que executa OS
  CLIENT_ADMIN      // Admin do cliente final
  CLIENT_USER       // Usuário do cliente final
  CLIENT_VIEWER     // Somente leitura no cliente
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  SCRAPPED        // Descartado
  BORROWED        // Emprestado
}

enum EquipmentCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  INITIAL_ACCEPTANCE   // Aceitação inicial
  EXTERNAL_SERVICE     // Serviço externo
  TECHNOVIGILANCE      // Tecnovigilância
  TRAINING             // Treinamento
  IMPROPER_USE         // Utilização inadequada
  DEACTIVATION         // Inativação
}

enum RecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY     // Quinzenal
  MONTHLY
  QUARTERLY    // Trimestral
  SEMIANNUAL   // Semestral
  ANNUAL
  CUSTOM       // Personalizada — usa custom_interval_days
}

enum ServiceOrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  COMPLETED_APPROVED
  COMPLETED_REJECTED
  CANCELLED
}

enum ServiceOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum MovementType {
  TRANSFER    // Transferência definitiva
  LOAN        // Empréstimo temporário
}

enum MovementStatus {
  ACTIVE      // Em andamento
  RETURNED    // Devolvido
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  TELEGRAM
  WEBSOCKET
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum AttachmentEntity {
  EQUIPMENT
  SERVICE_ORDER
  MAINTENANCE
  INVOICE
  AVATAR
}

// ─────────────────────────────────────────────────────────────────────────────
// PLATFORM — Nível raiz do sistema (Admin Geral)
// ─────────────────────────────────────────────────────────────────────────────

model Platform {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companies Company[]

  @@map("platforms")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPANY — Empresa de manutenção (ex: Aria Engenharia)
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id         String        @id @default(uuid())
  platformId String        @map("platform_id")
  name       String
  slug       String        @unique  // aria-engenharia
  document   String?       @unique  // CNPJ
  email      String?
  phone      String?
  logoUrl    String?       @map("logo_url")
  status     CompanyStatus @default(ACTIVE)
  trialEndsAt DateTime?    @map("trial_ends_at")
  settings   Json?         // Configurações da empresa (tema, integrações etc.)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  deletedAt  DateTime?     @map("deleted_at")  // Soft delete

  platform Platform @relation(fields: [platformId], references: [id])

  clients   Client[]
  users     User[]

  @@index([platformId])
  @@index([slug])
  @@index([status])
  @@map("companies")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLIENT — Cliente da empresa de manutenção (ex: Hospital São Lucas)
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id        String       @id @default(uuid())
  companyId String       @map("company_id")
  name      String
  document  String?      // CNPJ
  email     String?
  phone     String?
  address   Json?        // { street, number, city, state, zip }
  status    ClientStatus @default(ACTIVE)
  settings  Json?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  company Company @relation(fields: [companyId], references: [id])

  users         User[]
  costCenters   CostCenter[]
  locations     Location[]
  equipments    Equipment[]
  serviceOrders ServiceOrder[]
  maintenances  Maintenance[]
  schedules     MaintenanceSchedule[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("clients")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER — Usuário do sistema (todos os papéis)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  companyId    String?    @map("company_id")  // Null apenas para SUPER_ADMIN
  clientId     String?    @map("client_id")   // Null para COMPANY_* e TECHNICIAN
  name         String
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole
  status       UserStatus @default(ACTIVE)
  avatarUrl    String?    @map("avatar_url")
  phone        String?
  telegramChatId String?  @map("telegram_chat_id")

  // Auditoria de sessão
  lastLoginAt DateTime?  @map("last_login_at")
  lastLoginIp String?    @map("last_login_ip")

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  company Company? @relation(fields: [companyId], references: [id])
  client  Client?  @relation(fields: [clientId], references: [id])

  refreshTokens       RefreshToken[]
  serviceOrdersOwned  ServiceOrder[]         @relation("ServiceOrderRequester")
  serviceOrdersAssigned ServiceOrder[]       @relation("ServiceOrderTechnician")
  comments            ServiceOrderComment[]
  taskAssignments     ServiceOrderTask[]
  notifications       Notification[]
  movementsRequested  EquipmentMovement[]    @relation("MovementRequester")
  movementsApproved   EquipmentMovement[]    @relation("MovementApprover")
  maintenancesExecuted Maintenance[]

  @@index([companyId])
  @@index([clientId])
  @@index([companyId, clientId])
  @@index([email])
  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// REFRESH TOKEN — Controle de sessão e rotação de tokens
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")  // Hash bcrypt do token
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")  // Null = ainda válido
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// COST CENTER — Centro de custo (pertence ao cliente)
// ─────────────────────────────────────────────────────────────────────────────

model CostCenter {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  clientId    String    @map("client_id")
  name        String
  code        String?   // Código interno do cliente
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])

  equipments Equipment[]

  @@unique([clientId, code])
  @@index([companyId, clientId])
  @@map("cost_centers")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOCATION — Localização / setor (pertence ao cliente)
// ─────────────────────────────────────────────────────────────────────────────

model Location {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  clientId    String    @map("client_id")
  name        String    // Ex: "UTI - 3º Andar", "Bloco B - Sala 12"
  parentId    String?   @map("parent_id")  // Hierarquia de locais
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  client   Client    @relation(fields: [clientId], references: [id])
  parent   Location? @relation("LocationHierarchy", fields: [parentId], references: [id])
  children Location[] @relation("LocationHierarchy")

  equipments         Equipment[]
  movementsFrom      EquipmentMovement[] @relation("MovementOrigin")
  movementsTo        EquipmentMovement[] @relation("MovementDestination")
  currentEquipments  Equipment[]         @relation("CurrentLocation")

  @@index([companyId, clientId])
  @@index([clientId, parentId])
  @@map("locations")
}

// ─────────────────────────────────────────────────────────────────────────────
// EQUIPMENT TYPE / SUBTYPE — Categorização de equipamentos
// ─────────────────────────────────────────────────────────────────────────────

model EquipmentType {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")  // Tipos criados pela empresa
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  subtypes   EquipmentSubtype[]
  equipments Equipment[]

  @@index([companyId])
  @@map("equipment_types")
}

model EquipmentSubtype {
  id          String   @id @default(uuid())
  typeId      String   @map("type_id")
  companyId   String   @map("company_id")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  type       EquipmentType @relation(fields: [typeId], references: [id])
  equipments Equipment[]

  @@index([typeId])
  @@index([companyId])
  @@map("equipment_subtypes")
}

// ─────────────────────────────────────────────────────────────────────────────
// EQUIPMENT — Equipamento (pertence ao cliente)
// ─────────────────────────────────────────────────────────────────────────────

model Equipment {
  id             String               @id @default(uuid())
  companyId      String               @map("company_id")
  clientId       String               @map("client_id")
  costCenterId   String?              @map("cost_center_id")
  locationId     String?              @map("location_id")       // Local de instalação
  currentLocationId String?           @map("current_location_id") // Local atual (pode ser diferente após movimentação)
  typeId         String?              @map("type_id")
  subtypeId      String?              @map("subtype_id")

  // Identificação
  name           String
  brand          String?
  model          String?
  serialNumber   String?              @map("serial_number")
  patrimonyNumber String?             @map("patrimony_number")
  anvisaNumber   String?              @map("anvisa_number")

  // Aquisição
  purchaseValue  Decimal?             @map("purchase_value")    @db.Decimal(12, 2)
  purchaseDate   DateTime?            @map("purchase_date")     @db.Date
  invoiceNumber  String?              @map("invoice_number")
  warrantyStart  DateTime?            @map("warranty_start")    @db.Date
  warrantyEnd    DateTime?            @map("warranty_end")      @db.Date

  // Depreciação
  depreciationRate Decimal?           @map("depreciation_rate") @db.Decimal(5, 2) // % ao ano
  currentValue   Decimal?             @map("current_value")     @db.Decimal(12, 2)
  lastDepreciationCalc DateTime?      @map("last_depreciation_calc")

  // Características técnicas
  ipAddress      String?              @map("ip_address")
  operatingSystem String?             @map("operating_system")
  btus           Int?
  voltage        String?
  power          String?

  // Status e criticidade
  status         EquipmentStatus      @default(ACTIVE)
  criticality    EquipmentCriticality @default(MEDIUM)
  observations   String?

  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  deletedAt      DateTime?            @map("deleted_at")

  client          Client            @relation(fields: [clientId], references: [id])
  costCenter      CostCenter?       @relation(fields: [costCenterId], references: [id])
  location        Location?         @relation(fields: [locationId], references: [id])
  currentLocation Location?         @relation("CurrentLocation", fields: [currentLocationId], references: [id])
  type            EquipmentType?    @relation(fields: [typeId], references: [id])
  subtype         EquipmentSubtype? @relation(fields: [subtypeId], references: [id])

  attachments     Attachment[]
  serviceOrders   ServiceOrder[]
  maintenances    Maintenance[]
  movements       EquipmentMovement[]
  schedules       MaintenanceSchedule[]

  @@index([companyId, clientId])
  @@index([clientId, status])
  @@index([clientId, typeId])
  @@index([serialNumber])
  @@index([patrimonyNumber])
  @@map("equipments")
}

// ─────────────────────────────────────────────────────────────────────────────
// MAINTENANCE SCHEDULE — Regra de recorrência da manutenção preventiva
// ─────────────────────────────────────────────────────────────────────────────

model MaintenanceSchedule {
  id              String         @id @default(uuid())
  companyId       String         @map("company_id")
  clientId        String         @map("client_id")
  equipmentId     String         @map("equipment_id")
  title           String
  description     String?
  maintenanceType MaintenanceType @map("maintenance_type")
  recurrenceType  RecurrenceType  @map("recurrence_type")
  customIntervalDays Int?        @map("custom_interval_days") // Usado quando recurrenceType = CUSTOM
  estimatedDurationMin Int?      @map("estimated_duration_min") // Duração estimada em minutos
  assignedTechnicianId String?   @map("assigned_technician_id") // Técnico padrão

  // Controle de execução
  startDate       DateTime        @map("start_date")       @db.Date
  endDate         DateTime?       @map("end_date")         @db.Date  // Null = sem fim
  nextRunAt       DateTime        @map("next_run_at")      // Próxima execução
  lastRunAt       DateTime?       @map("last_run_at")      // Última execução
  isActive        Boolean         @default(true) @map("is_active")

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  client      Client    @relation(fields: [clientId], references: [id])
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  maintenances Maintenance[]

  @@index([companyId, clientId])
  @@index([nextRunAt, isActive])
  @@index([equipmentId])
  @@map("maintenance_schedules")
}

// ─────────────────────────────────────────────────────────────────────────────
// MAINTENANCE — Registro de uma manutenção (instância do schedule ou avulsa)
// ─────────────────────────────────────────────────────────────────────────────

model Maintenance {
  id           String          @id @default(uuid())
  companyId    String          @map("company_id")
  clientId     String          @map("client_id")
  equipmentId  String          @map("equipment_id")
  scheduleId   String?         @map("schedule_id")      // Null = manutenção avulsa
  technicianId String?         @map("technician_id")
  type         MaintenanceType
  title        String
  description  String?
  scheduledAt  DateTime?       @map("scheduled_at")
  startedAt    DateTime?       @map("started_at")
  completedAt  DateTime?       @map("completed_at")
  observations String?

  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  client     Client               @relation(fields: [clientId], references: [id])
  equipment  Equipment            @relation(fields: [equipmentId], references: [id])
  schedule   MaintenanceSchedule? @relation(fields: [scheduleId], references: [id])
  technician User?                @relation(fields: [technicianId], references: [id])

  serviceOrders ServiceOrder[]
  attachments   Attachment[]

  @@index([companyId, clientId])
  @@index([equipmentId])
  @@index([scheduleId])
  @@index([technicianId])
  @@map("maintenances")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE ORDER — Ordem de serviço
// ─────────────────────────────────────────────────────────────────────────────

model ServiceOrder {
  id              String               @id @default(uuid())
  companyId       String               @map("company_id")
  clientId        String               @map("client_id")
  equipmentId     String               @map("equipment_id")
  maintenanceId   String?              @map("maintenance_id")  // Vinculada à manutenção
  requesterId     String               @map("requester_id")    // Quem abriu
  technicianId    String?              @map("technician_id")   // Quem executa
  number          Int                  // Número sequencial por empresa
  title           String
  description     String
  status          ServiceOrderStatus   @default(OPEN)
  priority        ServiceOrderPriority @default(MEDIUM)
  resolution      String?              // Descrição da resolução
  internalNotes   String?              @map("internal_notes")  // Notas internas (só empresa)
  estimatedHours  Decimal?             @map("estimated_hours") @db.Decimal(6, 2)
  actualHours     Decimal?             @map("actual_hours")    @db.Decimal(6, 2)
  scheduledFor    DateTime?            @map("scheduled_for")
  startedAt       DateTime?            @map("started_at")
  completedAt     DateTime?            @map("completed_at")
  approvedAt      DateTime?            @map("approved_at")
  approvedById    String?              @map("approved_by_id")

  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  deletedAt       DateTime?            @map("deleted_at")

  client      Client      @relation(fields: [clientId], references: [id])
  equipment   Equipment   @relation(fields: [equipmentId], references: [id])
  maintenance Maintenance? @relation(fields: [maintenanceId], references: [id])
  requester   User        @relation("ServiceOrderRequester", fields: [requesterId], references: [id])
  technician  User?       @relation("ServiceOrderTechnician", fields: [technicianId], references: [id])

  comments      ServiceOrderComment[]
  tasks         ServiceOrderTask[]
  attachments   Attachment[]
  statusHistory ServiceOrderStatusHistory[]
  notifications Notification[]

  @@unique([companyId, number])
  @@index([companyId, clientId])
  @@index([clientId, status])
  @@index([technicianId, status])
  @@index([equipmentId])
  @@index([createdAt])
  @@map("service_orders")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE ORDER STATUS HISTORY — Auditoria de mudanças de status
// ─────────────────────────────────────────────────────────────────────────────

model ServiceOrderStatusHistory {
  id             String             @id @default(uuid())
  serviceOrderId String             @map("service_order_id")
  fromStatus     ServiceOrderStatus? @map("from_status")
  toStatus       ServiceOrderStatus  @map("to_status")
  changedById    String             @map("changed_by_id")
  reason         String?
  createdAt      DateTime           @default(now()) @map("created_at")

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@map("service_order_status_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE ORDER COMMENT — Comunicação entre técnico e solicitante
// ─────────────────────────────────────────────────────────────────────────────

model ServiceOrderComment {
  id             String   @id @default(uuid())
  serviceOrderId String   @map("service_order_id")
  authorId       String   @map("author_id")
  content        String
  isInternal     Boolean  @default(false) @map("is_internal") // Só visível pela empresa
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id])
  attachments  Attachment[]

  @@index([serviceOrderId])
  @@map("service_order_comments")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE ORDER TASK — Tarefas internas estilo Kanban
// ─────────────────────────────────────────────────────────────────────────────

model ServiceOrderTask {
  id             String     @id @default(uuid())
  serviceOrderId String     @map("service_order_id")
  assignedToId   String?    @map("assigned_to_id")
  title          String
  description    String?
  status         TaskStatus @default(TODO)
  position       Int        @default(0)  // Ordem no kanban
  dueDate        DateTime?  @map("due_date")
  completedAt    DateTime?  @map("completed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation(fields: [assignedToId], references: [id])

  @@index([serviceOrderId, status])
  @@map("service_order_tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// EQUIPMENT MOVEMENT — Movimentação / empréstimo de equipamentos
// ─────────────────────────────────────────────────────────────────────────────

model EquipmentMovement {
  id              String         @id @default(uuid())
  companyId       String         @map("company_id")
  clientId        String         @map("client_id")
  equipmentId     String         @map("equipment_id")
  requesterId     String         @map("requester_id")
  approverId      String?        @map("approver_id")
  type            MovementType
  status          MovementStatus @default(ACTIVE)
  originLocationId      String   @map("origin_location_id")
  destinationLocationId String   @map("destination_location_id")
  reason          String?
  expectedReturnAt DateTime?     @map("expected_return_at")  // Para empréstimos
  returnedAt      DateTime?      @map("returned_at")
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  requester   User      @relation("MovementRequester", fields: [requesterId], references: [id])
  approver    User?     @relation("MovementApprover", fields: [approverId], references: [id])
  origin      Location  @relation("MovementOrigin", fields: [originLocationId], references: [id])
  destination Location  @relation("MovementDestination", fields: [destinationLocationId], references: [id])

  @@index([companyId, clientId])
  @@index([equipmentId, status])
  @@map("equipment_movements")
}

// ─────────────────────────────────────────────────────────────────────────────
// ATTACHMENT — Arquivos armazenados no MinIO
// ─────────────────────────────────────────────────────────────────────────────
model Attachment {
  id           String           @id @default(uuid())
  companyId    String           @map("company_id")
  clientId     String?          @map("client_id")
  entity       AttachmentEntity
  entityId     String           @map("entity_id")
  fileName     String           @map("file_name")
  storedName   String           @map("stored_name")
  bucket       String
  key          String
  mimeType     String           @map("mime_type")
  sizeBytes    Int              @map("size_bytes")
  uploadedById String           @map("uploaded_by_id")
  createdAt    DateTime         @default(now()) @map("created_at")

  serviceOrder   ServiceOrder?        @relation(fields: [entityId], references: [id], map: "attachments_service_order_fkey")
  comment        ServiceOrderComment? @relation(fields: [entityId], references: [id], map: "attachments_comment_fkey")
  equipment      Equipment?           @relation(fields: [entityId], references: [id], map: "attachments_equipment_fkey")
  maintenance    Maintenance?         @relation(fields: [entityId], references: [id], map: "attachments_maintenance_fkey")

  @@index([companyId, entity, entityId])
  @@index([bucket, key])
  @@map("attachments")
}


// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION — Registro de notificações enviadas
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id             String              @id @default(uuid())
  companyId      String              @map("company_id")
  userId         String              @map("user_id")         // Destinatário
  serviceOrderId String?             @map("service_order_id")
  channel        NotificationChannel
  status         NotificationStatus  @default(PENDING)
  title          String
  body           String
  metadata       Json?               // Dados extras (chatId Telegram, templateId etc.)
  sentAt         DateTime?           @map("sent_at")
  failedAt       DateTime?           @map("failed_at")
  failReason     String?             @map("fail_reason")
  retryCount     Int                 @default(0) @map("retry_count")
  readAt         DateTime?           @map("read_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id])
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id])

  @@index([userId, readAt])
  @@index([status, createdAt])
  @@index([companyId, createdAt])
  @@map("notifications")
}
